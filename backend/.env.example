# Django 설정 (복사: cp .env.example .env 후 필요 시 수정)
# SECRET_KEY 는 운영에서 반드시 새로 생성해 사용하세요.

SECRET_KEY=change-me-use-a-long-random-string-in-real-env
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# 관리자 페이지 URL 경로 (운영에서는 추측 불가능한 문자열 사용)
# ADMIN_URL_PATH=your-secret-admin-path

# Kakao Login (카카오 개발자 콘솔에서 발급)
# KAKAO_REST_API_KEY=your_rest_api_key
# KAKAO_CLIENT_SECRET=  # 선택 (보안 수준이 비밀 키 사용인 경우)
# code 로그인 시 redirect_uri 화이트리스트 (콘솔 등록 URI와 동일, 콤마로 여러 개)
# 예: KAKAO_REDIRECT_URIS=http://localhost:3000/login/kakao-callback,http://127.0.0.1:3000/login/kakao-callback

# ── Production (Railway) ──────────────────────────────────────────────────────

# Railway Postgres 플러그인 추가 시 자동으로 주입되는 환경변수 (직접 설정 불필요)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# DEBUG=False
# ALLOWED_HOSTS=your-app.up.railway.app
# 프론트 도메인(콤마 구분). 온보딩 HttpOnly 쿠키는 credentialed fetch에 필요
# CORS_ALLOWED_ORIGINS=https://www.example.com
#
# 온보딩 쿠키(기본값으로 충분하면 생략)
# SIGNUP_TOKEN_TIMEOUT_SEC=600
# ONBOARDING_SIGNUP_COOKIE_SAMESITE=None   # 크로스 도메인 시 None + Secure
# ONBOARDING_SIGNUP_COOKIE_SECURE=true
#
# 온보딩 개발 모드 — 로컬 크로스오리진 시에만 true (운영에서는 반드시 false 또는 미설정)
# true이면서 DEBUG=False이면 서버 시작이 차단됩니다
# ONBOARDING_DEV_MODE=false

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
# R2_BUCKET_NAME=your-bucket-name
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# R2_CUSTOM_DOMAIN=pub.yourdomain.com  # R2 커스텀 도메인 (선택)
