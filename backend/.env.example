# Django 설정 (복사: cp .env.example .env 후 필요 시 수정)
# SECRET_KEY 는 운영에서 반드시 새로 생성해 사용하세요.

SECRET_KEY=django-insecure-#^vtd+@d6n*o2l*xwm9uvhkte*l4z-@0s6f2yspg^!)s(jn*2%
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Kakao Login (카카오 개발자 콘솔에서 발급)
# KAKAO_REST_API_KEY=your_rest_api_key
# KAKAO_CLIENT_SECRET=  # 선택 (보안 수준이 비밀 키 사용인 경우)

# ── Production (Railway) ──────────────────────────────────────────────────────

# Railway Postgres 플러그인 추가 시 자동으로 주입되는 환경변수 (직접 설정 불필요)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# DEBUG=False
# ALLOWED_HOSTS=your-app.up.railway.app
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
# R2_BUCKET_NAME=your-bucket-name
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# R2_CUSTOM_DOMAIN=pub.yourdomain.com  # R2 커스텀 도메인 (선택)
